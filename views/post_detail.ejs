<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog IA — <%= post.title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Blog IA</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                aria-controls="navbarMain" aria-expanded="false" aria-label="Alternar menu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Início</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about">Sobre</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contact">Contato</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/posts">Posts</a></li>
                    <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
                    <li class="nav-item"><a class="nav-link" href="/register">Cadastrar</a></li>
                    <li class="nav-item"><a class="nav-link" href="/profile">Perfil</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/posts">Posts</a></li>
                <li class="breadcrumb-item active" aria-current="page"><%= post.title %></li>
            </ol>
        </nav>

        <article>
            <p class="text-muted small mb-2"><%= post.date %></p>
            <h1 class="h3 mb-4"><%= post.title %></h1>
            <% post.paragraphs.forEach(function(paragraph) { %>
            <p><%= paragraph %></p>
            <% }); %>
            <p class="small text-muted mt-4 mb-0">ID do post (rota): <%= id %></p>
            <a class="btn btn-outline-dark mt-3" href="/posts">Voltar aos posts</a>
        </article>
    </main>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container text-center">
            <p class="mb-1 small">&copy; 2026 Blog IA — projeto de aula</p>
            <p class="mb-0 text-secondary small">Navbar e footer repetidos em cada página (exercício: extrair parciais)</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
