<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog IA — Início</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Blog IA</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                aria-controls="navbarMain" aria-expanded="false" aria-label="Alternar menu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link active" href="/">Início</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about">Sobre</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contact">Contato</a></li>
                    <li class="nav-item"><a class="nav-link" href="/posts">Posts</a></li>
                    <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
                    <li class="nav-item"><a class="nav-link" href="/register">Cadastrar</a></li>
                    <li class="nav-item"><a class="nav-link" href="/profile">Perfil</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        <div class="p-4 p-md-5 mb-4 rounded-3 bg-light border">
            <h1 class="display-6">Inteligência artificial, em linguagem simples</h1>
            <p class="lead">Artigos curtos para quem está começando — projeto de aula com Express e EJS.</p>
            <a class="btn btn-dark" href="/posts">Ver todos os posts</a>
        </div>
        <h2 class="h5 mb-3">Últimos posts</h2>
        <div class="row g-3">
            <% for (const [id, p] of Object.entries(posts)) { %>
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <p class="small text-muted mb-1"><%= p.date %></p>
                        <h5 class="card-title"><%= p.title %></h5>
                        <p class="card-text small flex-grow-1"><%= p.excerpt %></p>
                        <a class="btn btn-outline-dark btn-sm mt-2 align-self-start" href="/post/<%= id %>">Ler post</a>
                    </div>
                </div>
            </div>
            <% } %>
        </div>
    </main>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container text-center">
            <p class="mb-1 small">&copy; 2026 Blog IA — projeto de aula</p>
            <p class="mb-0 text-secondary small">Navbar e footer repetidos em cada página (exercício: extrair parciais)</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
