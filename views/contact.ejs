<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog IA — Contato</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Blog IA</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                aria-controls="navbarMain" aria-expanded="false" aria-label="Alternar menu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Início</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about">Sobre</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/contact">Contato</a></li>
                    <li class="nav-item"><a class="nav-link" href="/posts">Posts</a></li>
                    <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
                    <li class="nav-item"><a class="nav-link" href="/register">Cadastrar</a></li>
                    <li class="nav-item"><a class="nav-link" href="/profile">Perfil</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        <h1 class="h3 mb-3">Contato</h1>
        <p class="text-muted">Formulário apenas visual — não envia dados.</p>
        <form class="row g-3" action="#" method="post">
            <div class="col-md-6">
                <label class="form-label" for="nome">Nome</label>
                <input type="text" class="form-control" id="nome" name="nome" placeholder="Seu nome">
            </div>
            <div class="col-md-6">
                <label class="form-label" for="email">E-mail</label>
                <input type="email" class="form-control" id="email" name="email" placeholder="voce@exemplo.com">
            </div>
            <div class="col-12">
                <label class="form-label" for="msg">Mensagem</label>
                <textarea class="form-control" id="msg" name="msg" rows="4" placeholder="Sua mensagem sobre o blog..."></textarea>
            </div>
            <div class="col-12">
                <button type="button" class="btn btn-dark" disabled>Enviar (simulação)</button>
            </div>
        </form>
    </main>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container text-center">
            <p class="mb-1 small">&copy; 2026 Blog IA — projeto de aula</p>
            <p class="mb-0 text-secondary small">Navbar e footer repetidos em cada página (exercício: extrair parciais)</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
