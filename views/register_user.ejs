<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog IA — Cadastro</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Blog IA</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                aria-controls="navbarMain" aria-expanded="false" aria-label="Alternar menu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Início</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about">Sobre</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contact">Contato</a></li>
                    <li class="nav-item"><a class="nav-link" href="/posts">Posts</a></li>
                    <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/register">Cadastrar</a></li>
                    <li class="nav-item"><a class="nav-link" href="/profile">Perfil</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <h1 class="h3 mb-3">Criar conta</h1>
                <p class="text-muted small">Formulário só para layout — não grava usuário.</p>
                <form action="#" method="post">
                    <div class="mb-3">
                        <label class="form-label" for="nome">Nome completo</label>
                        <input type="text" class="form-control" id="nome" name="nome">
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="email">E-mail</label>
                        <input type="email" class="form-control" id="email" name="email" autocomplete="email">
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="senha">Senha</label>
                        <input type="password" class="form-control" id="senha" name="senha" autocomplete="new-password">
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="senha2">Confirmar senha</label>
                        <input type="password" class="form-control" id="senha2" name="senha2" autocomplete="new-password">
                    </div>
                    <button type="button" class="btn btn-dark w-100" disabled>Cadastrar (simulação)</button>
                </form>
                <p class="mt-3 small mb-0">Já tem conta? <a href="/login">Faça login</a></p>
            </div>
        </div>
    </main>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container text-center">
            <p class="mb-1 small">&copy; 2026 Blog IA — projeto de aula</p>
            <p class="mb-0 text-secondary small">Navbar e footer repetidos em cada página (exercício: extrair parciais)</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
